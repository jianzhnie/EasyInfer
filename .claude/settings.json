{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(shellcheck *)",
      "Bash(shellcheck **/*.sh)",
      "Bash(bash -n *)",
      "Bash(bash -n **/*.sh)",
      "Bash(pre-commit run *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(grep *)",
      "Bash(which *)",
      "Bash(uvx *)",
      "Bash(npx *)",
      "Bash(git commit *)",
      "Bash(git push *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-init.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/shellcheck-hook.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-dangerous.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "git -C \"$CLAUDE_PROJECT_DIR\" branch --show-current 2>/dev/null | xargs -I{} printf 'branch:{}' ; changes=$(git -C \"$CLAUDE_PROJECT_DIR\" status --porcelain 2>/dev/null | wc -l | tr -d ' ') ; [ \"$changes\" -gt 0 ] && printf ' changes:%d' \"$changes\"",
    "padding": 5,
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "huggingface-skills@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ruflo-agent@ruflo": true,
    "ruflo-workflows@ruflo": true,
    "ruflo-adr@ruflo": true,
    "ruflo-autopilot@ruflo": true,
    "ruflo-browser@ruflo": true,
    "ruflo-knowledge-graph@ruflo": true,
    "github@claude-plugins-official": true,
  }
}
